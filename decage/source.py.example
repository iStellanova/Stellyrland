"""
source.py — Example declaration file for decage (Declarative Portage).

Define your desired @world set here.  Because this is a standard Python
file, you can use comments, constants, set operations, conditionals, or
any other Python construct to organise your package list.

decage expects a variable named PACKAGES — a list, tuple, set, or
frozenset of Portage atom strings (category/name format).

Usage:
    cp source.py.example source.py
    # Edit to taste, then:
    decage                  # dry-run diff
    decage --apply          # actually sync
"""

# You can split packages into logical groups and merge them however you like.
# Sets are recommended because ordering doesn't matter and duplicates are
# automatically ignored.

# ── System Base ───────────────────────────────────────────────────────────
_base = {
    "sys-kernel/gentoo-sources",        # Gentoo kernel sources.
    "sys-kernel/linux-firmware",        # Binary firmware blobs.
    "sys-apps/systemd",                 # Init system (or openrc — pick one).
    "sys-boot/grub",                    # Bootloader.
    "app-admin/sudo",                   # Privilege escalation.
    "net-misc/networkmanager",          # Network management.
    "net-misc/dhcpcd",                  # DHCP client.
}

# ── CLI & TUI Tools ──────────────────────────────────────────────────────
_cli = {
    "app-shells/zsh",                   # ZSH shell.
    "sys-apps/ripgrep",                 # Better grep.
    "sys-apps/fd",                      # Better find.
    "app-editors/neovim",               # Modal editor.
    "sys-process/btop",                 # System monitor.
    "dev-vcs/git",                      # Version control.
    "app-misc/fastfetch",               # System info fetch.
    "sys-apps/bat",                     # cat with wings.
    "app-misc/tmux",                    # Terminal multiplexer.
}

# ── Desktop / Wayland ────────────────────────────────────────────────────
_desktop = {
    "gui-wm/hyprland",                  # Wayland compositor.
    "gui-apps/waybar",                  # Status bar.
    "x11-terms/kitty",                  # GPU-accelerated terminal.
    "media-sound/pipewire",             # Audio server.
    "media-video/mpv",                  # Media player.
    "app-editors/vscodium",             # Code editor (FOSS VS Code).
}

# ── Fonts ────────────────────────────────────────────────────────────────
_fonts = {
    "media-fonts/noto",                 # Google Noto fonts.
    "media-fonts/noto-emoji",           # Emoji support.
    "media-fonts/jetbrains-mono",       # JetBrains Mono (Nerd patched).
}

# ── Development ──────────────────────────────────────────────────────────
_dev = {
    "dev-lang/python",                  # Python interpreter.
    "dev-lang/rust",                    # Rust toolchain.
    "sys-devel/gcc",                    # GNU C/C++ compiler.
    "dev-util/cmake",                   # Build system generator.
}

# ══════════════════════════════════════════════════════════════════════════
# Final merged set — this is what decage reads.
# ══════════════════════════════════════════════════════════════════════════
PACKAGES = _base | _cli | _desktop | _fonts | _dev
