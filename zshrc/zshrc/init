ZSH_THEME=""

plugins=(
  git
  sudo
  gentoolinux
  zsh-autosuggestions
  fast-syntax-highlighting
  copyfile
  copybuffer
  # ssh-agent
)

HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory

source $ZSH/oh-my-zsh.sh

if [[ $(tty) == *"pts"* ]]; then
  fastfetch
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

if command -v fzf &>/dev/null; then
  source <(fzf --zsh)
fi
